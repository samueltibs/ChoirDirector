# Choir Director - Environment Variables
# Copy this file to .env and fill in your actual values

# ----------------------------
# Supabase Configuration
# ----------------------------

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key - KEEP SECRET, bypasses Row Level Security
# Found in Project Settings > API > Project API keys
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Supabase anonymous/public key - safe to expose in client
# Found in Project Settings > API > Project API keys
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ----------------------------
# Kits AI Configuration
# ----------------------------

# Your Kits AI API key for voice synthesis and choir processing
# Found in your Kits AI dashboard under API settings
KITS_AI_API_KEY=your-kits-ai-api-key-here

# ----------------------------
# Authentication
# ----------------------------

# JWT secret used for verifying Supabase JWTs
# Found in Project Settings > API > JWT Settings
JWT_SECRET=your-supabase-jwt-secret-here

# ----------------------------
# Application Configuration
# ----------------------------

# Runtime environment: development | production | staging
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# Example for development: http://localhost:3000,http://localhost:5173
# Example for production: https://choirdirector.app,https://www.choirdirector.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Base URL for the API (used for constructing absolute URLs, webhooks, etc.)
# Development example: http://localhost:8000
# Production example: https://api.choirdirector.app
API_BASE_URL=http://localhost:8000
